{
  "$schema": "./starter-manifest-examples.schema.json",
  "exampleVersion": 1,
  "builderExamples": [
    {
      "target": "codex",
      "status": "partial",
      "exampleShape": "responses-runtime-helper",
      "example": {
        "name": "codex-runtime-helper-example",
        "runtimeBaseUrlEnv": "SWITCHYARD_RUNTIME_BASE_URL",
        "catalogCommand": "pnpm run switchyard:cli -- builder-kit --target codex --json",
        "request": {
          "provider": "chatgpt",
          "model": "gpt-4o",
          "lane": "web",
          "input": "Summarize the latest provider health snapshot."
        }
      },
      "safeClaims": [
        "partial Codex compatibility",
        "thin runtime bridge",
        "example helper config"
      ]
    },
    {
      "target": "claude-code",
      "status": "partial",
      "exampleShape": "message-runtime-helper",
      "example": {
        "name": "claude-code-runtime-helper-example",
        "runtimeBaseUrlEnv": "SWITCHYARD_RUNTIME_BASE_URL",
        "catalogCommand": "pnpm run switchyard:cli -- builder-kit --target claude-code --json",
        "request": {
          "provider": "claude",
          "model": "claude-sonnet-4-6",
          "lane": "web",
          "messages": [
            {
              "role": "user",
              "content": "Summarize the current auth status."
            }
          ]
        }
      },
      "safeClaims": [
        "partial Claude Code compatibility",
        "thin message/runtime bridge",
        "example helper config"
      ]
    },
    {
      "target": "openclaw",
      "status": "partial",
      "exampleShape": "delegated-runtime-helper",
      "example": {
        "name": "openclaw-runtime-helper-example",
        "runtimeBaseUrlEnv": "SWITCHYARD_RUNTIME_BASE_URL",
        "catalogCommand": "pnpm run switchyard:cli -- builder-kit --target openclaw --json",
        "request": {
          "provider": "chatgpt",
          "model": "gpt-4o",
          "lane": "web",
          "input": "Give me the current provider remediation summary."
        }
      },
      "safeClaims": [
        "partial OpenClaw compatibility",
        "delegation-first bridge",
        "example helper config"
      ]
    },
    {
      "target": "mcp",
      "status": "partial",
      "exampleShape": "read-only-runtime-inspector",
      "example": {
        "name": "switchyard-mcp-client-example",
        "startupCommand": "pnpm run switchyard:mcp -- --base-url http://127.0.0.1:4010",
        "toolCall": {
          "name": "switchyard.runtime.health",
          "arguments": {}
        }
      },
      "safeClaims": [
        "partial read-only MCP surface",
        "runtime inspection only",
        "example stdio client wiring"
      ]
    }
  ],
  "skillExamples": [
    {
      "id": "runtime-diagnostics-pack",
      "status": "partial",
      "exampleShape": "read-only-runtime-diagnostics",
      "example": {
        "name": "runtime-diagnostics-pack-example",
        "catalogCommand": "pnpm run switchyard:cli -- skill-pack --target runtime-diagnostics-pack --json",
        "steps": [
          "pnpm run switchyard:cli -- provider-status --provider chatgpt --json",
          "pnpm run switchyard:cli -- provider-diagnose --provider chatgpt --json",
          "pnpm run switchyard:cli -- provider-support-bundle --provider chatgpt --json"
        ]
      },
      "safeClaims": [
        "read-only diagnostics pack",
        "provider triage helper",
        "no invoke/write actions"
      ]
    },
    {
      "id": "docs-seo-sync-pack",
      "status": "partial",
      "exampleShape": "truth-sync-and-discoverability",
      "example": {
        "name": "docs-seo-sync-pack-example",
        "catalogCommand": "pnpm run switchyard:cli -- skill-pack --target docs-seo-sync-pack --json",
        "steps": [
          "pnpm run switchyard:cli -- surface-catalog --json",
          "cat docs/discoverability-keyword-truth.md",
          "cat docs/public-surface-support-matrix.md"
        ]
      },
      "safeClaims": [
        "truth-sync helper",
        "discoverability helper",
        "no marketing autopilot"
      ]
    }
  ]
}
