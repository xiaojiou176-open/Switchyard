  "skillExamples": [
    {
      "id": "runtime-diagnostics-pack",
      "status": "partial",
      "exampleShape": "read-only-runtime-diagnostics",
      "example": {
        "name": "runtime-diagnostics-pack-example",
        "catalogCommand": "pnpm run switchyard:cli -- skill-pack-route --target runtime-diagnostics-pack --json",
        "steps": [
          "pnpm run switchyard:cli -- skill-pack-route --target runtime-diagnostics-pack --json",
          "pnpm run switchyard:cli -- provider-status --provider chatgpt --json",
          "pnpm run switchyard:cli -- provider-diagnose --provider chatgpt --json",
          "pnpm run switchyard:cli -- provider-support-bundle --provider chatgpt --json"
        ]
      },
      "safeClaims": [
        "read-only diagnostics pack",
        "provider triage helper",
        "no invoke/write actions"
      ]
    },
    {
      "id": "docs-seo-sync-pack",
