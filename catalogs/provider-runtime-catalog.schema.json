{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/xiaojiou176-open/Switchyard/catalogs/provider-runtime-catalog.schema.json",
  "title": "Switchyard Provider Runtime Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "catalogVersion",
    "providers"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "catalogVersion": {
      "type": "integer",
      "minimum": 1
    },
    "providers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/provider"
      }
    }
  },
  "$defs": {
    "lane": {
      "type": "string",
      "enum": [
        "byok",
        "web-login"
      ]
    },
    "authMode": {
      "type": "string",
      "enum": [
        "byok",
        "web-login"
      ]
    },
    "stabilityTarget": {
      "type": "string",
      "enum": [
        "high-stability",
        "baseline"
      ]
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "providerId",
        "displayName",
        "lane",
        "authMode",
        "stabilityTarget",
        "truthfulMeaning",
        "capabilityMatrix",
        "dispatchPolicy",
        "doctorEntryPoints"
      ],
      "properties": {
        "providerId": {
          "type": "string",
          "minLength": 1
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "lane": {
          "$ref": "#/$defs/lane"
        },
        "authMode": {
          "$ref": "#/$defs/authMode"
        },
        "stabilityTarget": {
          "$ref": "#/$defs/stabilityTarget"
        },
        "truthfulMeaning": {
          "type": "string",
          "minLength": 1
        },
        "capabilityMatrix": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "text-generation",
            "streaming",
            "tool-calling",
            "image-input",
            "file-input",
            "official-api",
            "web-login"
          ],
          "properties": {
            "text-generation": { "type": "boolean" },
            "streaming": { "type": "boolean" },
            "tool-calling": { "type": "boolean" },
            "image-input": { "type": "boolean" },
            "file-input": { "type": "boolean" },
            "official-api": { "type": "boolean" },
            "web-login": { "type": "boolean" }
          }
        },
        "dispatchPolicy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "registeredLanes",
            "defaultLane",
            "laneOrder",
            "requiresCredentialStateMap",
            "autoDispatches"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "single-lane-provider",
                "credential-aware-auto-lane"
              ]
            },
            "registeredLanes": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/lane"
              },
              "minItems": 1
            },
            "defaultLane": {
              "$ref": "#/$defs/lane"
            },
            "laneOrder": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/lane"
              },
              "minItems": 1
            },
            "requiresCredentialStateMap": {
              "type": "boolean"
            },
            "autoDispatches": {
              "type": "boolean"
            }
          }
        },
        "doctorEntryPoints": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "serviceRoute",
            "cliCommand",
            "mcpTool",
            "providerCatalogTarget"
          ],
          "properties": {
            "serviceRoute": {
              "type": "string",
              "minLength": 1
            },
            "cliCommand": {
              "type": "string",
              "minLength": 1
            },
            "mcpTool": {
              "type": "string",
              "minLength": 1
            },
            "providerCatalogTarget": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
