# Switchyard local credentialed browser defaults
# Copy the values you really need into your local .env or shell profile.
# Do not commit real credentials or machine-specific secrets.

SWITCHYARD_BROWSER_MODE=isolated-chrome-root
SWITCHYARD_CHROME_USER_DATA_DIR=~/.cache/switchyard/browser/chrome-user-data
SWITCHYARD_CHROME_PROFILE_NAME=switchyard

# Repo-external dedicated disposable cache root
SWITCHYARD_EXTERNAL_CACHE_ROOT=~/.cache/switchyard
SWITCHYARD_CACHE_TTL_DAYS=7
SWITCHYARD_CACHE_MAX_BYTES=5368709120

# Optional advanced / fallback overrides
# Keep the managed fallback profile inside repo-local .runtime-cache/.
# SWITCHYARD_WEB_AUTH_USER_DATA_DIR=.runtime-cache/switchyard-web-auth-browser
# SWITCHYARD_WEB_AUTH_CDP_URL=http://127.0.0.1:39222
# SWITCHYARD_WEB_AUTH_EXISTING_PROFILE_CDP_URL=http://127.0.0.1:9338
# SWITCHYARD_WEB_AUTH_EXISTING_BROWSER_SESSION_URL=http://127.0.0.1:9338
